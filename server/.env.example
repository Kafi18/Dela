# true = встроенная БД (без установки PostgreSQL), удобно после git clone
# false = настоящий PostgreSQL (Docker или локальный)
DELA_EMBEDDED_DB=true

JWT_SECRET=super_secret_key_change_me
PORT=4000

# Ниже нужны только если DELA_EMBEDDED_DB=false
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_NAME=shareholder_voting
# DB_SSL=false
# DATABASE_URL=postgres://...
