# Вариант 1: отдельные переменные
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
# Для локального Docker из репозитория: пароль postgres (см. docker-compose.yml)
# Для своего PostgreSQL: укажите свой пароль
DB_PASSWORD=postgres
DB_NAME=shareholder_voting
DB_SSL=false

# Вариант 2: одна строка
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/shareholder_voting

JWT_SECRET=super_secret_key_change_me
PORT=4000
